# Upstash Redis — connected via Vercel Marketplace integration.
# Vercel adds these two variables automatically when the integration is linked.
UPSTASH_REDIS_REST_URL=your_upstash_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Admin secret for GET /api/subscribers?key=...
# Set this in Vercel dashboard under Settings > Environment Variables.
ADMIN_SECRET=choose_a_strong_secret
