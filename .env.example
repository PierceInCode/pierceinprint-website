# Vercel KV (Redis) — create a KV store in the Vercel dashboard under Storage > KV,
# then link it to this project. Vercel will add these two variables automatically.
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token

# Admin secret for GET /api/subscribers?key=...
# Set this in Vercel dashboard under Settings > Environment Variables.
ADMIN_SECRET=choose_a_strong_secret
